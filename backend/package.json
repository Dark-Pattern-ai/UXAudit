{
  "name": "uxaudit-backend",
  "version": "1.0.0",
  "description": "UXAudit - AI 기반 다크패턴 탐지 백엔드",
  "main": "server.js",
  "scripts": {
  "start": "node server.js",
  "dev": "nodemon server.js",
  "dev:mock": "cross-env USE_MOCK_AI=true nodemon server.js",
  "dev:pressuring": "cross-env USE_MOCK_AI=true MOCK_CATEGORY=PRESSURING nodemon server.js",
  "test:api": "node test/testApi.js"
},
  "dependencies": {
    "axios": "^1.7.0",
    "cors": "^2.8.5",
    "express": "^4.19.0",
    "form-data": "^4.0.0",
    "multer": "^1.4.5-lts.1",
    "tesseract.js": "^5.1.0"
  },
  "devDependencies": {
    "cross-env": "^10.1.0",
    "nodemon": "^3.1.0"
  }
}
