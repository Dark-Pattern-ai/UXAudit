# ── 백엔드 환경변수 ─────────────────────────────────
# 이 파일을 복사해서 .env 로 사용하세요.
# cp .env.example .env

# 서버 포트
PORT=3000

# AI 서버 주소
# 로컬 실행 시: http://localhost:8000
# Docker 실행 시: http://ai-server:8000  (docker-compose 내부 통신)
AI_SERVER_URL=http://localhost:8000

# Mock AI 모드 (true: AI 서버 없이 테스트, false: 실제 AI 서버 사용)
USE_MOCK_AI=false

# Mock 카테고리 고정 (USE_MOCK_AI=true 일 때만 사용)
# 값: NORMAL | MISLEADING | OBSTRUCTING | PRESSURING | EXPLOITING
# 비워두면 매 요청마다 라운드로빈 순환
MOCK_CATEGORY=
